<script id="site-script" src="{{{uiRootPath}}}/js/site.js" data-ui-root-path="{{{uiRootPath}}}"></script>
<script async src="{{{uiRootPath}}}/js/vendor/highlight.js"></script>
<script src="{{{uiRootPath}}}/js/nav-tabs.js"></script>
<script src="{{{uiRootPath}}}/js/cookie-banner.js"></script>
{{#if (eq env.SITE_SEARCH_PROVIDER 'algolia')}}
{{#if site.keys.algoliaAppId}}
<script src="https://cdn.jsdelivr.net/npm/@docsearch/js@3"></script>
<script>
  docsearch({
    container: '#docsearch',
    appId: '{{site.keys.algoliaAppId}}',
    apiKey: '{{site.keys.algoliaApiKey}}',
    indexName: '{{site.keys.algoliaIndexName}}',
    placeholder: 'Search the docs',
  })
</script>
{{/if}}
{{/if}}
