<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item navbar-brand-link" href="{{{or site.url siteRootPath}}}">
        <img class="navbar-logo" src="{{{uiRootPath}}}/img/arcadedb-logo.png" alt="ArcadeDB">
      </a>
      {{#if env.SITE_SEARCH_PROVIDER}}
      <div class="navbar-item search hide-for-print">
        <div id="search-field" class="field">
          <input id="search-input" type="text" placeholder="Search the docs"{{#if page.home}} autofocus{{/if}}>
        </div>
      </div>
      {{/if}}
      <button class="navbar-burger" aria-controls="topbar-nav" aria-expanded="false" aria-label="Toggle main menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <a class="navbar-item" href="https://arcadedb.com" target="_blank" rel="noopener">Website</a>
        <a class="navbar-item" href="https://github.com/ArcadeData/arcadedb" target="_blank" rel="noopener">GitHub</a>
        <a class="navbar-item" href="https://github.com/ArcadeData/arcadedb/releases" target="_blank" rel="noopener">Releases</a>
        <a class="navbar-item" href="https://github.com/ArcadeData/arcadedb/discussions" target="_blank" rel="noopener">Community</a>
        <div class="navbar-item">
          <span class="control">
            <a class="button is-primary" href="https://arcadedb.com/pricing.html" target="_blank" rel="noopener">Pricing &amp; Support</a>
          </span>
        </div>
      </div>
    </div>
  </nav>
</header>
